<div class="items">
    {{#each items}}
    <div class="item" data-item-id="{{_id}}">
        <div class="type">
            <i class="fas {{itemIcon type}}" title="{{localize (concat "TYPES.Item." type)}}"></i>

            {{#if subtype }}
            <i class="fas {{itemSubtypeIcon type subtype}}" title="{{localize (concat "HEART.Item." type ".types." subtype)}}"></i>
            {{/if}}
        </div>
        <div class="name">
            {{name}}
        </div>
        <div>
            <i class="fas fa-eye" data-action="view-item"></i>
            {{#if editable}}
                {{#if deletable}}
                <i class="fas fa-trash" data-action="delete-item"></i>
                {{else}}
                    {{#if active}}
                    <i class="fas fa-square-check" data-action="deactivate-item"></i>
                    {{else}}
                    <i class="fas fa-square-xmark" data-action="activate-item"></i>
                    {{/if}}
                {{/if}}
            {{/if}}
        </div>
    </div>
    {{/each}}
</div>