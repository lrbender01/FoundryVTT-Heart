{
  "name": "heart",
  "version": "2.0.0",
  "description": "CSS compiler for the Heart system",
  "scripts": {
    "build": "sass src/scss/heart.scss css/heart.css --style=expanded --no-source-map",
    "watch": "sass src/scss/heart.scss css/heart.css --style=expanded --source-map --watch",
    "grammar": "node src/build_parsers.js"
  },
  "browserslist": [
    "last 3 versions"
  ],
  "author": "Asacolips",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "sass": "^1.53.0",
    "pegjs": "^0.10.0",
    "moduloze": "^0.9.1",
    "yaml": "^2.7.0",
    "@foundryvtt/foundryvtt-cli": "^1.0.4"
  },
  "dependencies": {}
}