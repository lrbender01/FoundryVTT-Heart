{
  "name": "heart",
  "version": "2.0.0",
  "description": "CSS compiler for the Heart system",
  "scripts": {
    "build-css": "sass src/scss/heart.scss css/heart.css --style=expanded --no-source-map",
    "watch-css": "sass src/scss/heart.scss css/heart.css --style=expanded --source-map --watch",
    "build-grammar": "node src/build_parsers.js",
    "update-system": "node src/update-system-manifest.js"
  },
  "browserslist": [
    "last 3 versions"
  ],
  "author": "Asacolips",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@foundryvtt/foundryvtt-cli": "^1.0.4",
    "moduloze": "^0.9.1",
    "pegjs": "^0.10.0",
    "sass": "^1.53.0",
    "typescript": "^5.8.3",
    "yaml": "^2.7.0"
  }
}
